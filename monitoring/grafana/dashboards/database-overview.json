{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "PostgreSQL — Active Connections",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "pg_stat_activity_count{datname=\"nivesh_db\"}", "legendFormat": "active" }
      ],
      "fieldConfig": {
        "defaults": { "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 90 }] } }
      }
    },
    {
      "title": "PostgreSQL — Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(pg_stat_user_tables_seq_scan{datname=\"nivesh_db\"}[5m])", "legendFormat": "seq scans/s" },
        { "expr": "rate(pg_stat_user_tables_idx_scan{datname=\"nivesh_db\"}[5m])", "legendFormat": "idx scans/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Redis — Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "redis_memory_used_bytes / redis_memory_max_bytes", "legendFormat": "used %" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "red", "value": 0.8 }] } }
      }
    },
    {
      "title": "Redis — Throughput",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "cmds/s" },
        { "expr": "redis_evicted_keys_total", "legendFormat": "evictions (total)" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Neo4j — Active Transactions",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "neo4j_transaction_active", "legendFormat": "active txns" }
      ]
    },
    {
      "title": "MongoDB — Operations/sec",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(mongodb_op_counters_total{type=\"insert\"}[5m])", "legendFormat": "insert" },
        { "expr": "rate(mongodb_op_counters_total{type=\"query\"}[5m])", "legendFormat": "query" },
        { "expr": "rate(mongodb_op_counters_total{type=\"update\"}[5m])", "legendFormat": "update" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "ClickHouse — Query Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(ClickHouseProfileEvents_Query[5m])", "legendFormat": "queries/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": {
        "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["database", "nivesh", "infrastructure"],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "Prometheus" } }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Database Overview",
  "uid": "nivesh-database-overview",
  "version": 1
}
