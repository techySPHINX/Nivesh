# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/nivesh
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=nivesh

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=nivesh

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ClickHouse Configuration
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=nivesh

# Kafka Configuration
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=nivesh-backend
KAFKA_GROUP_ID=nivesh-consumer-group

# AI Configuration - Local LLM via Ollama
# Primary: LLaMA-3-8B-Instruct (best finance reasoning, fits 8GB VRAM)
# Fallback: Mistral-7B-Instruct (fast, concise financial answers)
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_PRIMARY_MODEL=llama3:8b-instruct-q4_K_M
LLM_FALLBACK_MODEL=mistral:7b-instruct-q4_K_M
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# GCP Configuration (optional - for other GCP services, not LLM)
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
GCP_CREDENTIALS_PATH=

# Vertex AI Configuration (deprecated - using local LLM instead)
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1

# Security Configuration
JWT_SECRET=change-this-secret-key-to-something-secure
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Configuration
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# Encryption Configuration
ENCRYPTION_KEY=change-this-32-char-key-now!!!!!
ENCRYPTION_ALGORITHM=aes-256-gcm

# Bcrypt Configuration
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
