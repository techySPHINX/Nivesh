# ==============================================================
# Nivesh Backend — Development Dockerfile
# ==============================================================
# Hot-reload enabled via volume mount + nest start --watch
# ==============================================================

FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# Install dependencies first (cache layer)
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy prisma schema and generate client
COPY prisma/ ./prisma/
RUN pnpm prisma generate

# Source is mounted via docker-compose volume — no COPY needed
# The volume mount (./backend:/app) overwrites everything except node_modules

EXPOSE 3000

CMD ["pnpm", "run", "dev"]
